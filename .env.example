# AWS
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock
BEDROCK_LLM_MODEL=anthropic.claude-haiku-4-5
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=tavern-ai-srd

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# S3
S3_BUCKET_NAME=tavern-ai-srd-docs
S3_SRD_PREFIX=srd/

# DynamoDB
DYNAMODB_TABLE_NAME=tavern-ai-sessions

# App
APP_ENV=dev
APP_PORT=8000